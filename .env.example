# T2AutoTron 2.0 - Environment Configuration
# Copy this file to .env and fill in your values

# ===== SECURITY =====
# PIN for authentication (4-6 digits recommended)
# IMPORTANT: Change this from the default!
APP_PIN=1234

# Session secret for authentication (generate with: openssl rand -base64 32)
SESSION_SECRET=your-random-secret-here

# ===== SERVER =====
# Node environment (development or production)
NODE_ENV=development

# Server port
PORT=3000

# ===== HOME ASSISTANT =====
# Home Assistant host URL
HA_HOST=http://192.168.1.78:8123

# Home Assistant long-lived access token
HA_TOKEN=your_ha_token_here

# ===== PHILIPS HUE =====
# Hue Bridge IP address
HUE_BRIDGE_IP=192.168.1.x

# Hue API username (generated during pairing)
HUE_USERNAME=your_hue_username_here

# ===== WEATHER =====
# OpenWeatherMap API key (get from https://openweathermap.org/api)
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Ambient Weather API key
AMBIENT_WEATHER_API_KEY=your_ambient_weather_api_key_here

# Ambient Weather Application key
AMBIENT_WEATHER_APP_KEY=your_ambient_weather_app_key_here

# Ambient Weather MAC address
AMBIENT_WEATHER_MAC=your_device_mac_here

# ===== TELEGRAM (Optional) =====
# Telegram bot token for notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# ===== DATABASE (Optional) =====
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/t2autotron

# ===== LOGGING =====
# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Verbose logging (true/false)
VERBOSE_LOGGING=false
